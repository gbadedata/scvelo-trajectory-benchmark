# RNA velocity trajectory pipeline configuration.
# Copy to .env and adjust values as needed.
# All variables are prefixed with VEL_ to avoid collisions.

# Preprocessing
# VEL_N_TOP_GENES=2000
# VEL_N_PCS=30
# VEL_N_NEIGHBORS=30

# Velocity computation
# VEL_VELOCITY_MODE=stochastic
# VEL_VELOCITY_N_TOP_GENES=2000

# Clustering
# VEL_LEIDEN_RESOLUTION=0.8

# Benchmark
# VEL_BENCHMARK_SEED=42
# VEL_TRAJECTORY_RHO_THRESHOLD=0.5
# VEL_HIDDEN_BRANCH_TYPE=Epsilon

# Reproducibility
# VEL_RANDOM_SEED=42
